#: HTM_po_nelkul%5Cframe_properties.htm%2Bhtml.body.p:18-1
msgid ""
"The Frame Properties Dialog is a multi-page dialog box. Use this dialog to "
"modify general settings, validation rules, events, or to fine tune a frame's "
"position and size."
msgstr ""

#: HTM_po_nelkul%5Cframe_properties.htm%2Bhtml.body.p:19-1
msgid ""
"To access the properties for a frame, press <b>INSERT+F2</b> to open the Run "
"JAWS Manager dialog. Select Frame Viewer from the list and press <b>ENTER</b>. "
"<b>TAB</b> to the frame and press <b>ALT+ENTER</b>."
msgstr ""

