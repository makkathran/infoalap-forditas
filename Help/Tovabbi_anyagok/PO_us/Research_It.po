#: HTM_po_nelkul%5CResearch_It.htm%2Bhtml.body.h1:8-2
msgctxt "HTM_po_nelkul\\Research_It.htm+html.body.h1:8-2"
msgid "Research It"
msgstr ""

#: HTM_po_nelkul%5CResearch_It.htm%2Bhtml.body.p:9-2
msgid ""
"For a quick overview, see <a href=\"#OnTheFly\">Research It On the Fly</a>, "
"or continue reading the following introduction."
msgstr ""

#: HTM_po_nelkul%5CResearch_It.htm%2Bhtml.body.p:10-2
msgid ""
"Research It is a versatile tool that provides quick access to data while "
"also making it easy to return to your primary task. It uses what is known as "
"a lookup source and the Results Viewer to find information, whether it is "
"the meaning of a word, top news stories, and more. Using just a few "
"keystrokes, you can launch Research It from any application on your "
"computer. The following describes keystrokes, available lookup sources, and "
"various ways to launch and use Research It."
msgstr ""

#: HTM_po_nelkul%5CResearch_It.htm%2Bhtml.body.ul.li:12-4
msgctxt "HTM_po_nelkul\\Research_It.htm+html.body.ul.li:12-4"
msgid "Keystrokes"
msgstr ""

#: HTM_po_nelkul%5CResearch_It.htm%2Bhtml.body.ul.li:13-4
msgctxt "HTM_po_nelkul\\Research_It.htm+html.body.ul.li:13-4"
msgid "Lookup Sources"
msgstr ""

#: HTM_po_nelkul%5CResearch_It.htm%2Bhtml.body.ul.li:14-4
msgid "Examples Showing How to Use Research It"
msgstr ""

#: HTM_po_nelkul%5CResearch_It.htm%2Bhtml.body.ul.li:15-4
msgctxt "HTM_po_nelkul\\Research_It.htm+html.body.ul.li:15-4"
