msgid "Text Filters"
msgstr ""

#: HTM_po_nelkul%5Cevents.htm%2Bhtml.body.p:28-1
msgctxt "HTM_po_nelkul\\events.htm+html.body.p:28-1"
msgid "Event Scope"
msgstr ""

#: HTM_po_nelkul%5Cevents.htm%2Bhtml.body.p:29-1
