#: HTM_po_nelkul%5Cgeneral_application_keystrokes-an.htm%2Bhtml.head.title:12-1
msgid "Additional Notes on General windows Application Keystrokes"
msgstr ""

#: HTM_po_nelkul%5Cgeneral_application_keystrokes-an.htm%2Bhtml.body.h1:17-1
msgid "Additional Notes on General Windows Application Keystrokes"
msgstr ""

#: HTM_po_nelkul%5Cgeneral_application_keystrokes-an.htm%2Bhtml.body.h2:18-1
msgid "Exit the Active Application (ALT+F4)"
msgstr ""

#: HTM_po_nelkul%5Cgeneral_application_keystrokes-an.htm%2Bhtml.body.p:19-1
msgid ""
"If this keystroke is pressed while an unsaved file is opened in the active "
"application, you will often be asked if you wish to save the file before "
"exiting."
msgstr ""

#: HTM_po_nelkul%5Cgeneral_application_keystrokes-an.htm%2Bhtml.body.h2:20-1
msgid "Open the Application Control Menu (ALT+SPACEBAR)"
msgstr ""

#: HTM_po_nelkul%5Cgeneral_application_keystrokes-an.htm%2Bhtml.body.p:21-1
msgid ""
"The Control menu gives you access to menu items that allow you to change the "
"window state between restored, minimized, and maximized; move the window; or "
"close the window."
msgstr ""

#: HTM_po_nelkul%5Cgeneral_application_keystrokes-an.htm%2Bhtml.body.h2:22-1
msgid "Move to the Menu Bar (ALT)"
msgstr ""

#: HTM_po_nelkul%5Cgeneral_application_keystrokes-an.htm%2Bhtml.body.p:23-1
msgid ""
"This keystroke places the PC Cursor focus on the first menu on the menu bar "
"without displaying the contents of the menu. Use the <b>RIGHT ARROW</b> or "
"<b>LEFT ARROW</b> to select another menu on the menu bar. Press <b>UP ARROW</"
"b> or <b>DOWN ARROW</b> to open the menu and navigate through the menu items."
msgstr ""

#: HTM_po_nelkul%5Cgeneral_application_keystrokes-an.htm%2Bhtml.body.h2:24-1
msgid "Cancel or Close a Menu (ESC or ALT)"
msgstr ""

#: HTM_po_nelkul%5Cgeneral_application_keystrokes-an.htm%2Bhtml.body.p:25-1
msgid ""
"ESC collapses one level of a menu. If the File menu is displayed, pressing "
"<b>ESC</b> closes it and moves focus to the Menu bar. Pressing <b>ESC</b> "
"again returns focus to the application window. <b>ALT</b> closes a menu and "
"returns focus to the application window."
msgstr ""

#: HTM_po_nelkul%5Cgeneral_application_keystrokes-an.htm%2Bhtml.body.div.table.tbody.tr.td.p:30-1
msgid "Back"
msgstr ""
