#: HTM_po_nelkul%5Cusing_the_jaws_cursor.htm%2Bhtml.body.h1:17-1
msgctxt "HTM_po_nelkul\\using_the_jaws_cursor.htm+html.body.h1:17-1"
msgid "Using the JAWS Cursor"
msgstr ""

#: HTM_po_nelkul%5Cusing_the_jaws_cursor.htm%2Bhtml.body.p:18-1
msgid ""
"The JAWS Cursor is very useful when working in Windows. It corresponds to "
"the system mouse. The JAWS Cursor is used to manipulate the system mouse, "
"read static text to which the PC Cursor does not have access, and to access "
"other parts of Windows to which the PC Cursor cannot be moved. The JAWS "
"Cursor is also used to provide a quick overview of the information currently "
"available on the screen. Press <b>NUM PAD DASH</b> to make the JAWS Cursor "
"active."
msgstr ""

#: HTM_po_nelkul%5Cusing_the_jaws_cursor.htm%2Bhtml.body.p:19-1
msgid "Find information in the following areas:"
msgstr ""

#: HTM_po_nelkul%5Cusing_the_jaws_cursor.htm%2Bhtml.body.p:20-1
