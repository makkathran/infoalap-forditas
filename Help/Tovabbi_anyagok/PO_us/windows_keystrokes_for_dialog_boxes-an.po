#: HTM_po_nelkul%5Cwindows_keystrokes_for_dialog_boxes-an.htm%2Bhtml.body.h2:18-1
msgid "Move to Another Page (CTRL+TAB)"
msgstr ""

#: HTM_po_nelkul%5Cwindows_keystrokes_for_dialog_boxes-an.htm%2Bhtml.body.p:19-1
msgid ""
"In a multi-page dialog box, this keystroke moves focus to the next page (or tab). In "
"some dialogs, after cycling through all pages, this keystroke goes back to the "
"initial page, but in others, it stops at the last page."
msgstr ""

#: HTM_po_nelkul%5Cwindows_keystrokes_for_dialog_boxes-an.htm%2Bhtml.body.h2:20-1
msgid "Reverse Direction through Pages (CTRL+SHIFT+TAB)"
msgstr ""

#: HTM_po_nelkul%5Cwindows_keystrokes_for_dialog_boxes-an.htm%2Bhtml.body.p:21-1
msgid ""
"In a multi-page dialog box, this keystroke moves focus to the previous page (or tab). "
"In some dialogs, after cycling through all pages, this keystroke goes back to the "
"last page, but in others, it stops at the initial page."
msgstr ""

#: HTM_po_nelkul%5Cwindows_keystrokes_for_dialog_boxes-an.htm%2Bhtml.body.h2:22-1
msgid "Select/Deselect in List View (SPACEBAR or CTRL+SPACEBAR)"
msgstr ""

#: HTM_po_nelkul%5Cwindows_keystrokes_for_dialog_boxes-an.htm%2Bhtml.body.p:23-1
msgid ""
"To select multiple list items, press and hold down <b>CTRL</b> and use the <b>UP "
"ARROW</b> or <b>DOWN</b> <b>ARROW</b> keys to move to items you want to select. Still "
"holding down <b>CTRL</b>, press <b>SPACEBAR</b> to select items. Press <b>SPACEBAR</"
"b> a second time to unselect an item."
msgstr ""

