#: HTM_po_nelkul%5Ckeystrokes_for_using_the_clipboard.htm%2Bhtml.body.p:44-1
msgid ""
"<b style=\"font-weight: bold;\">Tip:</b> You also can press <b>INSERT+WINDOWS "
"Key+C</b> to copy selected text to the FSClipboard. Text that you copied with "
"this keystroke is added to any text that you have previously copied to the "
"Clipboard, instead of replacing it. This allows you to continue adding text to "
"the Clipboard until you are ready to paste it into a document. For more "
"information, see <a href=\"../../using_jaws/Using_the_Clipboard.htm\">Using the "
"Clipboard</a>."
msgstr ""

