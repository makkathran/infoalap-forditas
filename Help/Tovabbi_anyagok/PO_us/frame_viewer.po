msgstr ""

#: HTM_po_nelkul%5Cframe_viewer.htm%2Bhtml.body.table.tbody.tr.td.p:181-1
msgid "Delete Frame"
msgstr ""

#: HTM_po_nelkul%5Cframe_viewer.htm%2Bhtml.body.table.tbody.tr.td.p:184-1
msgid "ALT+D"
msgstr ""

#: HTM_po_nelkul%5Cframe_viewer.htm%2Bhtml.body.table.tbody.tr.td.p:189-1
msgid "Close Frames List"
msgstr ""

#: HTM_po_nelkul%5Cframe_viewer.htm%2Bhtml.body.table.tbody.tr.td.p:192-1
msgid "ALT+C"
msgstr ""

#: HTM_po_nelkul%5Cframe_viewer.htm%2Bhtml.body.table.tbody.tr.td.p:197-1
msgid "Move to Frame"
msgstr ""

#: HTM_po_nelkul%5Cframe_viewer.htm%2Bhtml.body.table.tbody.tr.td.p:200-1
msgid "ALT+M"
msgstr ""

#: HTM_po_nelkul%5Cframe_viewer.htm%2Bhtml.body.p:204-1
msgid ""
"<b style=\"font-weight: bold;\">Note</b>: You can only move to active "
"frames, but you can modify the properties for any frame in the list."
msgstr ""

#: HTM_po_nelkul%5Cframe_viewer.htm%2Bhtml.body.div.table.tbody.tr.td.p:210-1
msgid "Back"
msgstr ""

#: HTM_po_nelkul%5Cframe_viewer.htm%2Bhtml.body.div.table.tbody.tr.td.p:216-1
msgid "Next"
msgstr ""
